<?php
session_start();

if (!isset($_SESSION['username'])) {
    header("Location: login.php");
    exit();
}

$userName = $_SESSION['username'];

$userData = json_decode(file_get_contents("users.json"), true);
$cardsData = json_decode(file_get_contents("pokemon_data.json"), true);

if (isset($userData[$userName])) {
    $userBalance = $userData[$userName]['balance'];
    if($userName == "Admin"){
        $userEmail = "";
    }
    else{
        $userEmail = $userData[$userName]['email'];
    }
}
$sellSuccess = "";
$newAdminCards = [];
if (isset($_POST['sellCard'])) {
    $cardId = $_POST['sellCard'];
    if (!empty($userData[$userName]["owned_cards"]) && in_array($cardId, $userData[$userName]["owned_cards"])) {
        $index = array_search($cardId, $userData[$userName]["owned_cards"]);

        unset($userData[$userName]['owned_cards'][$index]);
        $admin= "Admin";
        if (!isset($userData[$admin]["owned_cards"])) {
            $userData[$admin]["owned_cards"] = [];
        }
        array_push($userData[$admin]["owned_cards"], $cardId);
        $userBalance += $cardsData[$cardId]['price'] * 0.9;
        $sellSuccess = "A kártya sikeresen eladva.";

        $userData[$userName]['balance'] = $userBalance;
        file_put_contents("users.json", json_encode($userData, JSON_PRETTY_PRINT));
    }
}
?>

