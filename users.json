    <div class="container">
        <?php 
            if(!empty($sellSuccess)){
                echo '<h1 style = "color: green">' . $sellSuccess. '</h1>';
            }
        ?>
        <h2>Felhasználónév: <?php echo $userName ?></h2>
        <h2>Email cím: <?php echo $userEmail ?></h2>
        <h2>Egyenleg: <?php echo $userBalance ?></h2>
        <br>
        <h2 class="owned_cards">Birtokolt kártyák:</h2>
        <div id="card-list">
        <?php 
        foreach ($cardsData as $cardId => $card) {
            if (in_array($cardId, $userData[$userName]["owned_cards"])) {
                echo '<div class="pokemon-card">';
                echo '<div class="image clr-' . $card['type'] . '">';
                echo '<img src="' . $card['image'] . '" alt="">';
                echo '</div>';
                echo '<div class="details">';
                echo '<h2><a href="http://localhost/php_beadando/details.php?id=' . $cardId . '">' . $card['name'] . '</a></h2>';
                echo '<span class="card-type"><span class="icon">🏷</span> ' . $card['type'] . '</span>';
                echo '<span class="attributes">';
                echo '<span class="card-hp"><span class="icon">❤</span> ' . $card['hp'] . '</span>';
                echo '<span class="card-attack"><span class="icon">⚔</span> ' . $card['attack'] . '</span>';
                echo '<span class="card-defense"><span class="icon">🛡</span> ' . $card['defense'] . '</span>';
                echo '</span>';
                echo '</div>';
                echo '<div class="buy">';
                echo '<form method="post" action="user_data.php">';
                echo '<input type="hidden" name="sellCard" value="' . $cardId . '">';
                echo '<button type="submit" class="invisible-button" style="border: none; padding: 0; background: none; cursor: pointer;color: var(--clr-white);    font-size: 20px;">';
                echo '<span title = "Ha eladod a kártyát, vissza kapod az ár 90%-át. Ebben az esetben amennyit visszakapsz: '.round($card['price']*0.90).'" class="card-price"><span class="icon">💰</span>Eladás</span>';
                echo '</button>';
                echo '</form>';
                echo '</div>';
                echo '</div>';
            }
        }
        ?>
        </div>
